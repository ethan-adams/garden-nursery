[gd_resource type="Theme" load_steps=20 format=3 uid="uid://nursery_ui_theme"]

; Nursery workbench UI theme (art bible: paper/wood/slate work surfaces, no glossy
; panels, no translucent dashboards). Panels are opaque on purpose — the yard must
; never ghost through overlay text. Controller focus is a thick marigold ring.
;
; Fonts: Alegreya + Alegreya Sans (SIL OFL 1.1, see assets/fonts/OFL-*.txt).

[ext_resource type="FontFile" path="res://assets/fonts/AlegreyaSans-Regular.ttf" id="1_sans"]
[ext_resource type="FontFile" path="res://assets/fonts/AlegreyaSans-Bold.ttf" id="2_sans_bold"]
[ext_resource type="FontFile" path="res://assets/fonts/Alegreya-Variable.ttf" id="3_serif"]

[sub_resource type="FontVariation" id="serif_bold"]
base_font = ExtResource("3_serif")
variation_opentype = {
2003265652: 700
}

